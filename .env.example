# ==== Server ====
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
dbUser
Hoang292001

mongodb+srv://dbUser:<db_password>@cluster0.l5u05dy.mongodb.net/?appName=Cluster0
# ==== MongoDB ====
MONGODB_URI=mongodb://127.0.0.1:27017/backend_auth_db

# ==== JWT ====
# Sinh secret ngau nhien manh, vi du: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_access_secret_please_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_please_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==== Bcrypt ====
BCRYPT_SALT_ROUNDS=12

# ==== Account lockout ====
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# ==== Seed admin mac dinh (chay: npm run seed:admin) ====
DEFAULT_ADMIN_EMAIL=admin@company.com
DEFAULT_ADMIN_PASSWORD=Admin@12345
DEFAULT_ADMIN_FULLNAME=Super Admin

# ==== Cookie ====
COOKIE_DOMAIN=localhost
